<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="StringBuilder_Test" Id="{3fedb51e-9356-4535-8d2f-4a045221111f}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK StringBuilder_Test EXTENDS TcUnit.FB_TestSuite

]]></Declaration>
    <Implementation>
      <ST><![CDATA[AppendABCTo123EqualsABC123();
LeftOfABC123With3EqualsABC();
RightOfABC123With3Equals123();
InsertXYZAt3IntoABC123EqualsABCXYZ123();
MultipleOperations();]]></ST>
    </Implementation>
    <Method Name="AppendABCTo123EqualsABC123" Id="{aa6b89ed-4bdc-434e-afc7-026d1f7cb7d6}">
      <Declaration><![CDATA[METHOD AppendABCTo123EqualsABC123
VAR
    _StringBuilder : StringBuilder;
    _ResultString : STRING(2048) := '';
    _ExpectedResultString : STRING(2048) := 'ABC123';
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('AppendABCTo123EqualsABC123');

_ResultString := _StringBuilder.Append('ABC')
                               .Append('123')
                               .ToString();
                               
AssertEquals_String(Expected := _ExpectedResultString,
             Actual := _ResultString,
             Message := 'The result is not correct');

TEST_FINISHED();                             ]]></ST>
      </Implementation>
    </Method>
    <Method Name="InsertXYZAt3IntoABC123EqualsABCXYZ123" Id="{a190dc2d-7b2f-41c9-ae08-0c370db28329}">
      <Declaration><![CDATA[METHOD InsertXYZAt3IntoABC123EqualsABCXYZ123
VAR
    _StringBuilder : StringBuilder;
    _ResultString : STRING(2048) := '';
    _ExpectedResultString : STRING(2048) := 'ABCXYZ123';
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('InsertXYZAt3IntoABC123EqualsABCXYZ123');

_ResultString := _StringBuilder.Append('ABC123')
                               .InsertAt('XYZ', 3) 
                               .ToString();
                               
AssertEquals_String(Expected := _ExpectedResultString,
             Actual := _ResultString,
             Message := 'The result is not correct');

TEST_FINISHED();                             ]]></ST>
      </Implementation>
    </Method>
    <Method Name="LeftOfABC123With3EqualsABC" Id="{a59b1ba5-0175-4c78-a58a-4a8939734a4c}">
      <Declaration><![CDATA[METHOD LeftOfABC123With3EqualsABC
VAR
    _StringBuilder : StringBuilder;
    _ResultString : STRING(2048) := '';
    _ExpectedResultString : STRING(2048) := 'ABC';
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('LeftOfABC123With3EqualsABC');

_ResultString := _StringBuilder.Append('ABC')
                               .Append('123')
                               .Left(3)
                               .ToString();
                               
AssertEquals_String(Expected := _ExpectedResultString,
             Actual := _ResultString,
             Message := 'The result is not correct');

TEST_FINISHED();                             ]]></ST>
      </Implementation>
    </Method>
    <Method Name="MultipleOperations" Id="{7e99dbbd-f2f7-4ca5-9a93-e606634ec362}">
      <Declaration><![CDATA[METHOD MultipleOperations
VAR
    _StringBuilder : StringBuilder;
    _ResultString : STRING(2048) := '';
    _Expected_ResultStringString : STRING(2048) := 'ABCXYZ123';
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('MultipleOperations');

// --- Append ---
_ResultString := _StringBuilder.Reset()
                               .Append('ABC')
                               .Append('123')
                               .ToString();
AssertEquals_STRING('ABC123', _ResultString, 'Append ABC + 123 should produce ABC123');

// --- InsertAt ---
_ResultString := _StringBuilder.Reset()
                               .Append('ABC')
                               .InsertAt('XYZ', 2) // A B C → A B XYZ C
                               .ToString();
AssertEquals_STRING('ABXYZC', _ResultString, 'Insert XYZ at pos 2 should produce ABXYZC');

// --- Left ---
_ResultString := _StringBuilder.Reset()
                               .Append('HELLOWORLD')
                               .Left(5)
                               .ToString();
AssertEquals_STRING('HELLO', _ResultString, 'Left(5) should return HELLO');

// --- Right ---
_ResultString := _StringBuilder.Reset()
                               .Append('HELLOWORLD')
                               .Right(5)
                               .ToString();
AssertEquals_STRING('WORLD', _ResultString, 'Right(5) should return WORLD');

// --- RemoveAt ---
_ResultString := _StringBuilder.Reset()
                               .Append('ABCDE')
                               .RemoveAt(2, 2) // remove BC → ADE
                               .ToString();
AssertEquals_STRING('ADE', _ResultString, 'RemoveAt(2,2) should remove BC and produce ADE');

// --- Reset ---
_ResultString := _StringBuilder.Reset()
                               .ToString();
AssertEquals_STRING('', _ResultString, 'Reset should produce empty string');

TEST_FINISHED();  ]]></ST>
      </Implementation>
    </Method>
    <Method Name="RightOfABC123With3Equals123" Id="{e2fd2f63-e778-4065-baf4-c1e4ad69b2aa}">
      <Declaration><![CDATA[METHOD RightOfABC123With3Equals123
VAR
    _StringBuilder : StringBuilder;
    _ResultString : STRING(2048) := '';
    _ExpectedResultString : STRING(2048) := '123';
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('RightOfABC123With3Equals123');

_ResultString := _StringBuilder.Append('ABC')
                               .Append('123')
                               .Right(3)
                               .ToString();
                               
AssertEquals_String(Expected := _ExpectedResultString,
             Actual := _ResultString,
             Message := 'The result is not correct');

TEST_FINISHED();                             ]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>