    </Method>
    <Method Name="LeftOfABC123With3EqualsABC" Id="{a59b1ba5-0175-4c78-a58a-4a8939734a4c}">
      <Declaration><![CDATA[METHOD LeftOfABC123With3EqualsABC
VAR
    _StringBuilder : StringBuilder;
    _ResultString : STRING(2048) := '';
    _ExpectedResultString : STRING(2048) := 'ABC';
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('LeftOfABC123With3EqualsABC');

_ResultString := _StringBuilder.Append('ABC')
                               .Append('123')
                               .Left(3)
                               .ToString();
                               
AssertEquals_String(Expected := _ExpectedResultString,
             Actual := _ResultString,
             Message := 'The result is not correct');

TEST_FINISHED();                             ]]></ST>
      </Implementation>
    </Method>
    <Method Name="MultipleOperations" Id="{7e99dbbd-f2f7-4ca5-9a93-e606634ec362}">
      <Declaration><![CDATA[METHOD MultipleOperations
VAR
    _StringBuilder : StringBuilder;
    _ResultString : STRING(2048) := '';
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('MultipleOperations');

// --- Append ---
_ResultString := _StringBuilder.Reset()
                               .Append('ABC')
                               .Append('123')
                               .ToString();
AssertEquals_STRING('ABC123', _ResultString, 'Append ABC + 123 should produce ABC123');

// --- InsertAt ---
_ResultString := _StringBuilder.Reset()
                               .Append('ABC')
                               .InsertAt('XYZ', 2) // A B C → A B XYZ C
                               .ToString();
AssertEquals_STRING('ABXYZC', _ResultString, 'Insert XYZ at pos 2 should produce ABXYZC');

// --- Left ---
_ResultString := _StringBuilder.Reset()
                               .Append('HELLOWORLD')
                               .Left(5)
                               .ToString();
AssertEquals_STRING('HELLO', _ResultString, 'Left(5) should return HELLO');

// --- Right ---
_ResultString := _StringBuilder.Reset()
                               .Append('HELLOWORLD')
                               .Right(5)
                               .ToString();
AssertEquals_STRING('WORLD', _ResultString, 'Right(5) should return WORLD');

// --- RemoveAt ---
_ResultString := _StringBuilder.Reset()
                               .Append('ABCDE')
                               .RemoveAt(2, 2) // remove BC → ADE
                               .ToString();
AssertEquals_STRING('ADE', _ResultString, 'RemoveAt(2,2) should remove BC and produce ADE');

// --- Reset ---
_ResultString := _StringBuilder.Reset()
                               .ToString();
AssertEquals_STRING('', _ResultString, 'Reset should produce empty string');

TEST_FINISHED();  ]]></ST>
      </Implementation>
    </Method>
    <Method Name="RemoveDelimitedSubstring" Id="{c1f342dd-8711-4a15-9753-a84e0da98f72}">
      <Declaration><![CDATA[METHOD RemoveDelimitedSubstring
VAR
    _StringBuilder : StringBuilder;
    _ResultString : STRING(2048) := '';
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('RemoveDelimitedSubstring');

// Remove first delimited substring
_ResultString := _StringBuilder.Reset()
                               .Append('^/')
                               .Append('ABC/')
                               .Append('123')
                               .RemoveDelimitedSubstring('/', 1)
                               .ToString();
                               
AssertEquals_String(Expected := 'ABC/123',
             Actual := _ResultString,
             Message := 'Remove first delimited substring failed');

// Remove mid delimited substring
_ResultString := _StringBuilder.Reset()
                               .Append('^/')
                               .Append('ABC/')
                               .Append('123')
                               .RemoveDelimitedSubstring('/', 2)
                               .ToString();
                               
AssertEquals_String(Expected := '^/123',
             Actual := _ResultString,
             Message := 'Remove mid delimited substring failed');

// Remove last delimited substring
_ResultString := _StringBuilder.Reset()
                               .Append('^/')
                               .Append('ABC/')
                               .Append('123')
                               .RemoveDelimitedSubstring('/', 3)
                               .ToString();
                               
AssertEquals_String(Expected := '^/ABC',
             Actual := _ResultString,
             Message := 'Remove last delimited substring failed');

// Remove delimited substring with index 0 (not allowed: no operations)
_ResultString := _StringBuilder.Reset()
                               .Append('^/')
                               .Append('ABC/')
                               .Append('123')
                               .RemoveDelimitedSubstring('/', 0)
                               .ToString();
                               
AssertEquals_String(Expected := '^/ABC/123',
             Actual := _ResultString,
             Message := 'Remove delimited substring with index 0 failed');

// Remove delimited substring with index greater than available (no operations)
_ResultString := _StringBuilder.Reset()
                               .Append('^/')
                               .Append('ABC/')
                               .Append('123')
                               .RemoveDelimitedSubstring('/', 4)
                               .ToString();
                               
AssertEquals_String(Expected := '^/ABC/123',
             Actual := _ResultString,
             Message := 'Remove delimited substring with index greater than available failed');

// Remove delimited substring when only one substring with no delimiters
_ResultString := _StringBuilder.Reset()
                               .Append('ABC')
                               .RemoveDelimitedSubstring('/', 1)
                               .ToString();
                               
AssertEquals_String(Expected := '',
             Actual := _ResultString,
             Message := 'Remove delimited substring when only one substring with no delimiters');

TEST_FINISHED();                             ]]></ST>
      </Implementation>
    </Method>
