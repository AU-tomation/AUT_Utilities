<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="StringBuilder" Id="{8b6cce3d-fec6-455c-849a-88b106706848}" SpecialFunc="None">
    <Declaration><![CDATA[(*! <Summary>
StringBuilder provides several methods for building and manipulating a string.
It uses fluent interface allowing easy composition of various operations.
It is a wrapper around Beckhoff Tc2_Utilities: therefore it has similar limitations
</Summary> *)
FUNCTION_BLOCK PUBLIC StringBuilder IMPLEMENTS  IStringBuilder, ILimitedStringBuilder
VAR
	{attribute 'hide'}
	_BuildingString : STRING(GVL_Param_AUT_Utilities.StringBuilder_MaxStringLength);
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Method Name="Append" Id="{97928194-740a-46c9-9479-85912eaee214}">
      <Declaration><![CDATA[//! @Description Append a string to the string under construction
METHOD PUBLIC Append : IStringBuilder // Append text to the current built string.
VAR_INPUT
	Text : STRING(GVL_Param_AUT_Utilities.StringBuilder_MaxStringLength); //Text to append to current build string
END_VAR
VAR
    _BoolRes : BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[_BoolRes := Tc2_Utilities.CONCAT2(ADR(_BuildingString), ADR(Text), ADR(_BuildingString), SIZEOF(_BuildingString));
Append := THIS^;    // Fluent interface]]></ST>
      </Implementation>
    </Method>
    <Method Name="AppendWithFormat" Id="{60116ab5-037b-4083-8602-0f8aed205f47}">
      <Declaration><![CDATA[(*! <Summary>
Appends a formatted value using a printf-style format string.
</Summary> *)
METHOD AppendWithFormat : IStringBuilder // Returns the builder for fluent chaining.
VAR_INPUT
	Value : ANY;   // Value to format (any primitive type)
	Format : STRING(GVL_Param_AUT_Utilities.StringBuilder_MaxStringLength); // Printf-style format string (e.g. '%05d', '%.2f', '%X')
END_VAR
VAR
    _FormatString2 : Tc2_Utilities.FB_FormatString2;
    _FormattedText : STRING(GVL_Param_AUT_Utilities.StringBuilder_MaxStringLength);
    _BoolRes : BOOL;
    _BoolError : BOOL;
    _arg1 : T_Arg;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Format specifications (between [] are optional)
// %[flags][width][.precision].type

_arg1.cbLen := DINT_TO_UDINT(Value.diSize);
_arg1.pData := Value.pValue;
CASE Value.TypeClass OF
    __SYSTEM.TYPE_CLASS.TYPE_INT:      _arg1.eType := E_ArgType.ARGTYPE_INT;
    __SYSTEM.TYPE_CLASS.TYPE_DINT:     _arg1.eType := E_ArgType.ARGTYPE_DInt;
    __SYSTEM.TYPE_CLASS.TYPE_UINT:     _arg1.eType := E_ArgType.ARGTYPE_UInt;
    __SYSTEM.TYPE_CLASS.TYPE_UDINT:    _arg1.eType := E_ArgType.ARGTYPE_UDInt;
    __SYSTEM.TYPE_CLASS.TYPE_REAL:     _arg1.eType := E_ArgType.ARGTYPE_Real;
    __SYSTEM.TYPE_CLASS.TYPE_LREAL:    _arg1.eType := E_ArgType.ARGTYPE_LReal;
    __SYSTEM.TYPE_CLASS.TYPE_STRING:   _arg1.eType := E_ArgType.ARGTYPE_String;
    __SYSTEM.TYPE_CLASS.TYPE_BOOL:     _arg1.eType := E_ArgType.ARGTYPE_Bool;
    __SYSTEM.TYPE_CLASS.TYPE_BYTE:     _arg1.eType := E_ArgType.ARGTYPE_Byte;
    __SYSTEM.TYPE_CLASS.TYPE_WORD:     _arg1.eType := E_ArgType.ARGTYPE_Word;
    __SYSTEM.TYPE_CLASS.TYPE_DWORD:    _arg1.eType := E_ArgType.ARGTYPE_DWord;
ELSE
    _arg1.eType := E_ArgType.ARGTYPE_UNKNOWN;
    _BoolError := TRUE;
END_CASE

IF NOT _BoolError THEN
    _FormatString2(pFormatString := ADR(Format),
                   arg1 := _arg1,
                   pDstString := ADR(_FormattedText),
                   nDstSize := SIZEOF(_FormattedText),
                   bError => _BoolError);
END_IF

IF NOT _BoolError THEN
    Append(_FormattedText);
END_IF
AppendWithFormat := THIS^;    // Fluent interface]]></ST>
      </Implementation>
    </Method>
    <Method Name="AssignDelimitedSubstringTo" Id="{698e6e2e-63f1-4fb0-889a-0788275ac183}">
      <Declaration><![CDATA[(*! <Summary>
Extracts the Nth delimited token and copies it to Destination.
</Summary> *)
METHOD AssignDelimitedSubstringTo : IStringBuilder // Returns the builder for fluent chaining.
VAR_INPUT
    Delimiter : STRING(1); // Single-character delimiter
    SubstringIndex : UDINT; // 1-based index of the token to extract (0 returns empty string)
	Destination : POINTER TO STRING(GVL_Param_AUT_Utilities.StringBuilder_MaxStringLength); // Pointer to the destination string
    DestinationSize : UDINT; // Size in bytes of the destination string
END_VAR
VAR
    _CurrentPosition : UDINT := 0;
    _CurrentDelimiterPosition : UDINT := 0;
    _CurrentDelimiterIndex : UDINT := 0;
    _LeadingDelimiterPosition : UDINT := 0;
    _TrailingDelimiterPosition : UDINT := 0;
    _Substring : STRING(2048) := '';
    _Index : UDINT;
    _BoolRes : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// ATTENTION: pointer arithmetics is used to move inside string
IF SubstringIndex < 1 THEN
    // Assign empty string
    _BoolRes := Tc2_Utilities.STRNCPY(Destination, ADR(_Substring), DestinationSize);
    AssignDelimitedSubstringTo := THIS^;      // Fluent interface
    RETURN;
END_IF
REPEAT
    _CurrentDelimiterPosition := Tc2_Utilities.FIND2(ADR(_BuildingString) + _CurrentPosition, ADR(Delimiter));
    IF _CurrentDelimiterPosition > 0 THEN
        _CurrentPosition := _CurrentPosition + _CurrentDelimiterPosition;
        _CurrentDelimiterIndex := _CurrentDelimiterIndex + 1;
        IF _CurrentDelimiterIndex = (SubstringIndex - 1) THEN
            _LeadingDelimiterPosition := _CurrentPosition;
        END_IF
        IF _CurrentDelimiterIndex = SubstringIndex THEN
            _TrailingDelimiterPosition := _CurrentPosition;
        END_IF
    END_IF
UNTIL _CurrentDelimiterPosition = 0 OR _CurrentDelimiterIndex = SubstringIndex
END_REPEAT

IF _CurrentDelimiterIndex = 0 THEN
    // No delimiter was found: assign entire building string
    _BoolRes := Tc2_Utilities.STRNCPY(Destination, ADR(_BuildingString), DestinationSize);
ELSIF SubstringIndex > (_CurrentDelimiterIndex + 1) THEN
    // Requested substring not found: assign an empty string
    _BoolRes := Tc2_Utilities.STRNCPY(Destination, ADR(_Substring), DestinationSize);
ELSE
    // Delimiters were found: assign requested substring
    // NOTE: STRNCPY inserts a null terminator at the position of destination size (for copying n chars: destination size must be n + 1)
    IF SubstringIndex = 1 THEN
        _BoolRes := Tc2_Utilities.STRNCPY(ADR(_Substring), ADR(_BuildingString), _TrailingDelimiterPosition);
    ELSE
        _BoolRes := Tc2_Utilities.STRNCPY(ADR(_Substring), ADR(_BuildingString) + _LeadingDelimiterPosition, _TrailingDelimiterPosition - _LeadingDelimiterPosition);
    END_IF
    _BoolRes := Tc2_Utilities.STRNCPY(Destination, ADR(_Substring), DestinationSize);
END_IF
AssignDelimitedSubstringTo := THIS^;      // Fluent interface]]></ST>
      </Implementation>
    </Method>
    <Method Name="AssignTo" Id="{0a14c808-fbd9-4bbc-a2f1-b424d90eeaab}">
      <Declaration><![CDATA[(*! <Summary>
Copies the current built string into Destination.
</Summary> *)
METHOD AssignTo : IStringBuilder // Returns the builder for fluent chaining.
VAR_INPUT
	Destination : POINTER TO STRING(GVL_Param_AUT_Utilities.StringBuilder_MaxStringLength); // Pointer to the destination string
    DestinationSize : UDINT; // Size in bytes of the destination string
END_VAR
VAR
    _BoolRes : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[_BoolRes := Tc2_Utilities.STRNCPY(Destination, ADR(_BuildingString), DestinationSize);
AssignTo := THIS^;      // Fluent interface]]></ST>
      </Implementation>
    </Method>
    <Method Name="InsertAt" Id="{e92c66b5-b697-4308-a175-1131aa42cb77}">
      <Declaration><![CDATA[(*! <Summary>
Inserts Text at the given 1-based Position.
</Summary> *)
METHOD PUBLIC InsertAt : IStringBuilder // Returns the builder for fluent chaining.
VAR_INPUT
	Text : STRING(GVL_Param_AUT_Utilities.StringBuilder_MaxStringLength); // Text to insert
	Position : UDINT; // 1-based position at which to insert the text
END_VAR
VAR
    _BoolRes : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[_BoolRes := Tc2_Utilities.INSERT2(ADR(_BuildingString), ADR(Text), ADR(_BuildingString), SIZEOF(_BuildingString), Position);
InsertAt := THIS^;      // Fluent interface]]></ST>
      </Implementation>
    </Method>
    <Method Name="Left" Id="{8830457f-8ba5-4b91-b336-a8c2e5712763}">
      <Declaration><![CDATA[(*! <Summary>
Keeps only the first Length characters of the built string.
</Summary> *)
METHOD Left : IStringBuilder // Returns the builder for fluent chaining.
VAR_INPUT
	Length : UDINT; // Number of characters to keep from the left
END_VAR
VAR
    _BoolRes : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[_BoolRes := Tc2_Utilities.DELETE2(ADR(_BuildingString), ADR(_BuildingString), SIZEOF(_BuildingString), Tc2_Utilities.LEN2(ADR(_BuildingString)) - Length, Length + 1);
Left := THIS^;      // Fluent interface]]></ST>
      </Implementation>
    </Method>
    <Method Name="Mid" Id="{a790806c-0997-4e8a-953a-514ec7fcd716}">
      <Declaration><![CDATA[(*! <Summary>
Keeps Length characters starting at 1-based Position.
</Summary> *)
METHOD Mid : IStringBuilder // Returns the builder for fluent chaining.
VAR_INPUT
	Position : UDINT; // 1-based starting position
	Length : UDINT; // Number of characters to keep
END_VAR
VAR
    _BoolRes : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[_BoolRes := Tc2_Utilities.DELETE2(ADR(_BuildingString), ADR(_BuildingString), SIZEOF(_BuildingString), Position - 1, 1);
_BoolRes := Tc2_Utilities.DELETE2(ADR(_BuildingString), ADR(_BuildingString), SIZEOF(_BuildingString), Tc2_Utilities.LEN2(ADR(_BuildingString)) - Length, Length + 1);
Mid := THIS^;      // Fluent interface]]></ST>
      </Implementation>
    </Method>
    <Method Name="PadLeft" Id="{e4c48602-110f-44b4-a98f-ab2f3008da18}">
      <Declaration><![CDATA[(*! <Summary>
Pads the built string on the left with PaddingChar up to TotalLength.
</Summary> *)
METHOD PadLeft : IStringBuilder // Returns the builder for fluent chaining.
VAR_INPUT
    PaddingChar : STRING(1); // Single character used for padding
	TotalLength : UDINT; // Desired total length after padding
END_VAR
VAR
    _Index : UDINT;
    _PaddingString : STRING(GVL_Param_AUT_Utilities.StringBuilder_MaxStringLength) := '';
    _BoolRes : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF Tc2_Utilities.LEN2(ADR(_BuildingString)) < TotalLength THEN
    FOR _Index := 1 TO (TotalLength - Tc2_Utilities.LEN2(ADR(_BuildingString))) DO
        InsertAt(PaddingChar, 1);
    END_FOR
END_IF
PadLeft := THIS^;      // Fluent interface]]></ST>
      </Implementation>
    </Method>
    <Method Name="PadRight" Id="{f4859cef-2f49-40f4-b510-3cbecc19c1c4}">
      <Declaration><![CDATA[(*! <Summary>
Pads the built string on the right with PaddingChar up to TotalLength.
</Summary> *)
METHOD PadRight : IStringBuilder // Returns the builder for fluent chaining.
VAR_INPUT
    PaddingChar : STRING(1); // Single character used for padding
	TotalLength : UDINT; // Desired total length after padding
END_VAR
VAR
    _Index : UDINT;
    _PaddingString : STRING(GVL_Param_AUT_Utilities.StringBuilder_MaxStringLength) := '';
    _BoolRes : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF Tc2_Utilities.LEN2(ADR(_BuildingString)) < TotalLength THEN
    FOR _Index := 1 TO (TotalLength - Tc2_Utilities.LEN2(ADR(_BuildingString))) DO
        Append(PaddingChar);
    END_FOR
END_IF
PadRight := THIS^;      // Fluent interface]]></ST>
      </Implementation>
    </Method>
    <Method Name="RemoveAt" Id="{6c81872c-8f56-43aa-a82b-ba2a779ff3d2}">
      <Declaration><![CDATA[(*! <Summary>
Removes Length characters starting at 1-based Position.
</Summary> *)
METHOD RemoveAt : IStringBuilder // Returns the builder for fluent chaining.
VAR_INPUT
	Position : UDINT; // 1-based position from which to start removing
    Length : UDINT; // Number of characters to remove
END_VAR
VAR
    _BoolRes : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[_BoolRes := Tc2_Utilities.DELETE2(ADR(_BuildingString), ADR(_BuildingString), SIZEOF(_BuildingString), Length, Position);
RemoveAt := THIS^;      // Fluent interface]]></ST>
      </Implementation>
    </Method>
    <Method Name="RemoveDelimitedSubstring" Id="{0143fc6b-15b0-4de9-ba76-313e88c96427}">
      <Declaration><![CDATA[(*! <Summary>
Removes the Nth delimited token (and its trailing delimiter) from the built string.
</Summary> *)
METHOD RemoveDelimitedSubstring : IStringBuilder // Returns the builder for fluent chaining.
VAR_INPUT
    Delimiter : STRING(1); // Single-character delimiter
    SubstringIndex : UDINT; // 1-based index of the token to remove
END_VAR
VAR
    _CurrentPosition : UDINT := 0;
    _CurrentDelimiterPosition : UDINT := 0;
    _CurrentDelimiterIndex : UDINT := 0;
    _LeadingDelimiterPosition : UDINT := 0;
    _TrailingDelimiterPosition : UDINT := 0;
    _Substring : STRING(2048) := '';
    _Index : UDINT;
    _BoolRes : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// ATTENTION: pointer arithmetics is used in FIND2 function
IF SubstringIndex < 1 THEN
    RemoveDelimitedSubstring := THIS^;      // Fluent interface
    RETURN;
END_IF
REPEAT
    // Find next delimiter: the address point to beginning of string or to first char following last delimiter found (address arithmetic)
    _CurrentDelimiterPosition := Tc2_Utilities.FIND2(ADR(_BuildingString) + _CurrentPosition, ADR(Delimiter));
    IF _CurrentDelimiterPosition > 0 THEN
        // Delimiter found
        _CurrentPosition := _CurrentPosition + _CurrentDelimiterPosition;       //Base-1 string position
        _CurrentDelimiterIndex := _CurrentDelimiterIndex + 1;
        IF _CurrentDelimiterIndex = (SubstringIndex - 1) THEN
            _LeadingDelimiterPosition := _CurrentPosition;      //Base-1 string position
        END_IF
        IF _CurrentDelimiterIndex = SubstringIndex THEN
            _TrailingDelimiterPosition := _CurrentPosition;     //Base-1 string position
        END_IF
    ELSE
        // Delimiter not found: consider remaining string chunk as last substring
        IF _CurrentDelimiterIndex = (SubstringIndex - 1) THEN
            IF _CurrentDelimiterIndex > 0 THEN
                _LeadingDelimiterPosition := _LeadingDelimiterPosition - 1;
            END_IF
            _TrailingDelimiterPosition := LEN2(ADR(_BuildingString));
            _CurrentDelimiterIndex := _CurrentDelimiterIndex + 1;
        END_IF
    END_IF
UNTIL _CurrentDelimiterPosition = 0 OR _CurrentDelimiterIndex = SubstringIndex
END_REPEAT

IF _CurrentDelimiterIndex > 0 AND SubstringIndex = _CurrentDelimiterIndex THEN
    // Delimiters were found: remove requested substring
    _BoolRes := Tc2_Utilities.DELETE2(ADR(_BuildingString), ADR(_BuildingString), SIZEOF(_BuildingString), _TrailingDelimiterPosition - _LeadingDelimiterPosition, _LeadingDelimiterPosition + 1);
END_IF
RemoveDelimitedSubstring := THIS^;      // Fluent interface]]></ST>
      </Implementation>
    </Method>
    <Method Name="ReplaceAt" Id="{81e47fe5-7bcc-4c2a-8791-af280ee56b98}">
      <Declaration><![CDATA[(*! <Summary>
Replaces Length characters at 1-based Position with Text.
</Summary> *)
METHOD ReplaceAt : IStringBuilder // Returns the builder for fluent chaining.
VAR_INPUT
    Text : STRING(GVL_Param_AUT_Utilities.StringBuilder_MaxStringLength); // Replacement text
	Position : UDINT; // 1-based position of the first character to replace
    Length : UDINT; // Number of characters to replace
END_VAR
VAR
    _BoolRes : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[_BoolRes := Tc2_Utilities.REPLACE2(ADR(_BuildingString), ADR(Text), ADR(_BuildingString), SIZEOF(_BuildingString), Length, Position);
ReplaceAt := THIS^;      // Fluent interface]]></ST>
      </Implementation>
    </Method>
    <Method Name="Reset" Id="{3b4cc271-03d3-421f-b2fe-50bbd95d6cdb}">
      <Declaration><![CDATA[(*! <Summary>
Clears the built string to empty.
</Summary> *)
METHOD PUBLIC Reset : ILimitedStringBuilder // Returns the limited builder interface for fluent chaining.]]></Declaration>
      <Implementation>
        <ST><![CDATA[_BuildingString := '';
Reset := THIS^;     // Fluent interface]]></ST>
      </Implementation>
    </Method>
    <Method Name="Right" Id="{5c9eebce-16b4-4549-873c-40e74a589919}">
      <Declaration><![CDATA[(*! <Summary>
Keeps only the last Length characters of the built string.
</Summary> *)
METHOD Right : IStringBuilder // Returns the builder for fluent chaining.
VAR_INPUT
	Length : UDINT; // Number of characters to keep from the right
END_VAR
VAR
    _BoolRes : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[_BoolRes := Tc2_Utilities.DELETE2(ADR(_BuildingString), ADR(_BuildingString), SIZEOF(_BuildingString), Tc2_Utilities.LEN2(ADR(_BuildingString)) - Length, 1);
Right := THIS^;      // Fluent interface]]></ST>
      </Implementation>
    </Method>
    <Method Name="ToString" Id="{0701aa11-e1f1-41fa-9e08-587883568ffd}">
      <Declaration><![CDATA[(*! <Summary>
Returns the current built string.
</Summary> *)
METHOD PUBLIC ToString : STRING(GVL_Param_AUT_Utilities.StringBuilder_MaxStringLength) // The current built string.]]></Declaration>
      <Implementation>
        <ST><![CDATA[ToString := _BuildingString;]]></ST>
      </Implementation>
    </Method>
    <Method Name="ToWString" Id="{ff7ad9e4-7d5b-4ada-95f9-5a10d98dae67}">
      <Declaration><![CDATA[(*! <Summary>
Returns the current built string as a WSTRING.
</Summary> *)
METHOD ToWString : WSTRING(GVL_Param_AUT_Utilities.StringBuilder_MaxStringLength) // The current built string as WSTRING.]]></Declaration>
      <Implementation>
        <ST><![CDATA[ToWString := Tc2_Utilities.CHAR_TO_WCHAR(_BuildingString);]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>
